{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "noEmit": true,
    "skipLibCheck": true,
    "strict": false,
    "allowJs": false,
    "resolveJsonModule": true,
    "verbatimModuleSyntax": false,
    "isolatedModules": false
  },
  "include": [
    "extensions/**/*.ts"
  ]
}
