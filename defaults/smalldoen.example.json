{
  "ui": {
    "modeIndicatorText": "Orchestration mode"
  },
  "paths": {
    "plansDir": ".pi/smalldoen/plans",
    "memoryDir": ".pi/smalldoen/memory",
    "runsDir": ".pi/smalldoen/runs",
    "scoutReportsDir": ".pi/smalldoen/reports/scout",
    "reviewReportsDir": ".pi/smalldoen/reports/review"
  },
  "agents": {
    "orchestrator": {
      "name": "Orchestrator",
      "description": "Top-level orchestration controller",
      "provider": "github-copilot",
      "model": "claude-opus-4.6",
      "memoryDir": ".pi/smalldoen/memory/orchestrator"
    },
    "scout": {
      "name": "Scout",
      "description": "Codebase scout and documentation validator",
      "provider": "github-copilot",
      "model": "gemini-3-pro",
      "memoryDir": ".pi/smalldoen/memory/scout",
      "reportDir": ".pi/smalldoen/reports/scout"
    },
    "planner": {
      "name": "Planner",
      "description": "Versioned implementation planner",
      "provider": "github-copilot",
      "model": "claude-sonnet-4.5",
      "memoryDir": ".pi/smalldoen/memory/planner"
    },
    "engineer": {
      "name": "Engineer",
      "description": "Implementation worker for code and logic",
      "provider": "github-copilot",
      "model": "claude-sonnet-4.5",
      "memoryDir": ".pi/smalldoen/memory/engineer"
    },
    "designer": {
      "name": "Designer",
      "description": "Implementation worker for UI, UX, and frontend presentation",
      "provider": "github-copilot",
      "model": "claude-sonnet-4.5",
      "memoryDir": ".pi/smalldoen/memory/designer"
    },
    "reviewer": {
      "name": "Reviewer",
      "description": "Reviewer for changed files and affected files",
      "provider": "github-copilot",
      "model": "claude-opus-4.6",
      "memoryDir": ".pi/smalldoen/memory/reviewer",
      "reportDir": ".pi/smalldoen/reports/review"
    }
  }
}
